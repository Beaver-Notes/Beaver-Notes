{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Beaver Notes",
  "version": "5.0.0",
  "identifier": "com.danielerolli.beaver-notes",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "node scripts/tauri-dev-server.mjs",
    "beforeBuildCommand": "vite build --config vite.config.js"
  },
  "app": {
    "windows": [
      {
        "title": "Beaver Notes",
        "width": 1000,
        "height": 800,
        "minWidth": 600,
        "minHeight": 400,
        "decorations": true,
        "transparent": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' assets: data: blob: https:; media-src 'self' assets: file-assets: blob: https:; font-src 'self' data:; frame-src 'none'; object-src 'none'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "category": "Productivity",
    "icon": [
      "../buildResources/icon.png",
      "../buildResources/icon.icns",
      "../buildResources/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["bea"],
        "name": "Beaver Notes",
        "description": "Beaver Notes File",
        "mimeType": "application/x-beaver-notes"
      }
    ],
    "macOS": {
      "entitlements": "../buildResources/entitlements.mac.plist"
    },
    "linux": {
      "deb": { "depends": [] },
      "rpm": { "depends": [] }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Beaver-Notes/Beaver-Notes/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc0NjAyRTYyRDczQUY3QzkKUldUSjl6clhZaTVnZEgzLzBOOHNyYUdMOHkrRDBFY0ZkU3FRQUs2Z2YrbUVqTUt3VWFDWW5WSU8K"
    }
  }
}
