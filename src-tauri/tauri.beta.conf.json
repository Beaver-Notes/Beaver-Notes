{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Beaver Notes Beta",
  "version": "5.0.0-beta.1",
  "identifier": "com.beavernotes.beaver-notes",
  "build": {
    "removeUnusedCommands": true,
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "node scripts/tauri-dev-server.mjs",
    "beforeBuildCommand": "yarn vite build --config vite.config.js"
  },
  "app": {
    "windows": [
      {
        "title": "Beaver Notes Beta",
        "width": 1000,
        "height": 800,
        "minWidth": 600,
        "minHeight": 400,
        "decorations": true,
        "transparent": false,
        "dragDropEnabled": false,
        "disableInputAccessoryView": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' assets: data: blob: https:; media-src 'self' assets: file-assets: blob: https:; font-src 'self' data:; frame-src 'none'; object-src 'none'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "category": "Productivity",
    "icon": [
      "../buildResources/beta/icon.png",
      "../buildResources/beta/icon.icns",
      "../buildResources/beta/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["bea"],
        "name": "Beaver Notes",
        "description": "Beaver Notes File",
        "mimeType": "application/x-beaver-notes",
        "role": "Editor"
      },
      {
        "ext": ["md", "mdx"],
        "name": "Markdown",
        "description": "Markdown File",
        "mimeType": "text/markdown",
        "role": "Viewer"
      },
      {
        "ext": ["txt"],
        "name": "Plain Text",
        "description": "Plain Text File",
        "mimeType": "text/plain",
        "role": "Viewer"
      },
      {
        "ext": ["html"],
        "name": "HTML",
        "description": "HTML File",
        "mimeType": "text/html",
        "role": "Viewer"
      }
    ],
    "macOS": {
      "entitlements": "../buildResources/entitlements.mac.plist"
    },
    "linux": {
      "deb": {
        "depends": []
      },
      "rpm": {
        "depends": []
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Beaver-Notes/Beaver-Notes/releases/download/beta/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEwNkNFQ0E2NzY4NTUzNjIKUldSaVU0VjJwdXhzb0Z4TVF5NHZZa0ZXZWtOZTdrbmRoR3ZFclcrS0tQTERyN01SLzBRWk1YTHgK"
    }
  }
}
