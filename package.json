{
  "name": "beaver-notes",
  "type": "module",
  "private": true,
  "version": "5.0.0-beta.1",
  "author": "Daniele Rolli",
  "description": "Open-source notes that live where you choose: your device, your server, or ours.",
  "license": "MIT",
  "engines": {
    "node": ">=v18.0.0"
  },
  "homepage": "https://beavernotes.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/Beaver-Notes/Beaver-Notes"
  },
  "scripts": {
    "watch": "node scripts/watch.mjs",
    "build": "tauri build",
    "build:desktop": "tauri build",
    "build:beta": "tauri build --config src-tauri/tauri.beta.conf.json",
    "dev:beta": "tauri dev --config src-tauri/tauri.beta.conf.json",
    "release:beta": "tauri build --config src-tauri/tauri.beta.conf.json",
    "mobile:init:ios": "cargo tauri ios init --ci --skip-targets-install",
    "mobile:init:android": "cargo tauri android init --ci --skip-targets-install",
    "dev:ios": "cargo tauri ios dev",
    "build:ios": "cargo tauri ios build",
    "open:ios": "cargo tauri ios dev --open",
    "dev:android": "cargo tauri android dev",
    "build:android": "cargo tauri android build --apk --aab",
    "open:android": "cargo tauri android dev --open",
    "test:e2e": "bash scripts/run-e2e.sh",
    "test:e2e:install": "cargo install tauri-webdriver-automation || true",
    "test": "NODE_OPTIONS='--localstorage-file=/tmp/vitest-localstorage' vitest run",
    "test:watch": "NODE_OPTIONS='--localstorage-file=/tmp/vitest-localstorage' vitest",
    "lint": "oxlint --vue-plugin --max-warnings 0",
    "typecheck": "vue-tsc --noEmit",
    "tran-util": "node scripts/translationUtil.js",
    "tran-update": "node scripts/updateTranslations.js",
    "version:bump": "node scripts/bump-version.mjs",
    "version:bump:beta": "node scripts/bump-version.mjs"
  },
  "simple-git-hooks": {
    "pre-commit": "yarn lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,vue}": "oxlint --fix"
  },
  "devDependencies": {
    "@axe-core/webdriverio": "^4.12.1",
    "@benrbray/prosemirror-math": "^0.2.2",
    "@pinia/testing": "^2.0.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tauri-apps/cli": "^2",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/test-utils": "^2.4.11",
    "@wdio/cli": "^9.29.1",
    "@wdio/local-runner": "^9.29.1",
    "@wdio/mocha-framework": "^9.29.1",
